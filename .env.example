# Copy this file to .env and fill in your secrets.
# Never commit your real .env to version control.

# Kimi (Moonshot) — production LLM, OpenAI-compatible API.
# Get a key at https://platform.moonshot.cn
MOONSHOT_API_KEY=replace-with-your-kimi-key

# OpenAI — only needed to reproduce the benchmark with GPT-4o as judge.
# Leave blank if you're just running the app.
OPENAI_API_KEY=
